<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ==================== 顶部大刘海 ==================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingBottom="12dp"
        android:paddingHorizontal="16dp">

        <!-- 店铺名称 -->
        <TextView
            android:id="@+id/tv_shop_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="我的小店"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:gravity="center" />

        <!-- 在线状态指示器 -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🟢 运行正常"
            android:textSize="13sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginTop="4dp"
            android:gravity="center" />

    </LinearLayout>

    <!-- ==================== 快捷指令入口 ==================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginTop="1dp">

        <EditText
            android:id="@+id/et_command"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/edit_bg"
            android:padding="12dp"
            android:hint="📢 卖了[商品] [数量]件 [价格]块"
            android:textSize="14sp"
            android:singleLine="true" />

        <Button
            android:id="@+id/btn_send_command"
            style="@style/AppButton.Medium"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="发送"
            android:textSize="15sp"
            android:minWidth="64dp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- ==================== 快捷记账区域（垂直列表） ==================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_marginTop="1dp"
        android:background="@color/surface">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="快捷记账"
            android:textSize="18sp"
            android:textColor="@color/primary_text"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- 垂直滚动列表容器 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/ll_category_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:divider="@drawable/divider_green"
                android:showDividers="middle">
            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <!-- ==================== 底部导航栏 ==================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/surface"
        android:gravity="center"
        android:orientation="horizontal"
        android:elevation="2dp">

        <Button
            android:id="@+id/btn_nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="🏠\n首页"
            android:textSize="11sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:backgroundTint="@color/primary"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btn_nav_bill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="📊\n账单"
            android:textSize="11sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:backgroundTint="@android:color/transparent"
            android:textColor="@color/text_secondary" />

        <Button
            android:id="@+id/btn_nav_stock"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="📦\n进货"
            android:textSize="11sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:backgroundTint="@android:color/transparent"
            android:textColor="@color/text_secondary" />

        <Button
            android:id="@+id/btn_nav_my"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="👤\n我的"
            android:textSize="11sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:backgroundTint="@android:color/transparent"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

</LinearLayout>