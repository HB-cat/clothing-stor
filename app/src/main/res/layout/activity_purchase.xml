<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="进货入库"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- 选择商品 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择商品"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp"/>
            <Spinner
                android:id="@+id/sp_product"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_card_white"
                android:padding="12dp"
                android:layout_marginBottom="14dp"/>

            <!-- 进价 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="进价："
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">
                <EditText
                    android:id="@+id/et_cost_price"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_white"
                    android:padding="12dp"
                    android:hint="如：60"
                    android:inputType="numberDecimal"
                    android:textSize="16sp"/>
            </LinearLayout>

            <!-- 尺码 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="尺码："
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp"/>
            <Spinner
                android:id="@+id/sp_size"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_card_white"
                android:padding="12dp"
                android:layout_marginBottom="14dp"/>

            <!-- 颜色 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="颜色："
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp"/>
            <Spinner
                android:id="@+id/sp_color"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_card_white"
                android:padding="12dp"
                android:layout_marginBottom="14dp"/>

            <!-- 数量 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="数量："
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/et_quantity"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_card_white"
                android:padding="12dp"
                android:hint="如：5"
                android:inputType="number"
                android:textSize="16sp"
                android:layout_marginBottom="14dp"/>

            <!-- 其他属性 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="其他属性"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp"/>
            <LinearLayout
                android:id="@+id/ll_other_attrs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp"/>

            <!-- 总金额卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:padding="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="总金额"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tv_total_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¥0"
                    android:textSize="26sp"
                    android:textColor="@color/primary_text"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- 确认入库 -->
            <Button
                android:id="@+id/btn_save_purchase"
                style="@style/AppButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="确认入库"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- 底部导航栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_card_white"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="4dp">

            <Button
                android:id="@+id/btn_nav_home"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="🏠\n首页"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:background="@drawable/bg_nav_default"
                android:textColor="@color/text_secondary"
                android:gravity="center" />

            <Button
                android:id="@+id/btn_nav_bill"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="📊\n账单"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:background="@drawable/bg_nav_default"
                android:textColor="@color/text_secondary"
                android:gravity="center" />

            <Button
                android:id="@+id/btn_nav_stock"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="📦\n进货"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:background="@drawable/bg_nav_selected"
                android:textColor="@android:color/white"
                android:gravity="center" />

            <Button
                android:id="@+id/btn_nav_my"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="👤\n我的"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:background="@drawable/bg_nav_default"
                android:textColor="@color/text_secondary"
                android:gravity="center" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>