<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_card_white">

    <!-- 年月导航 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btn_cal_prev_month"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="◀"
            android:textSize="18sp"
            android:backgroundTint="#EEEEEE"
            android:padding="0dp" />

        <TextView
            android:id="@+id/tv_cal_month_year"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2026年5月"
            android:textSize="18sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:gravity="center" />

        <Button
            android:id="@+id/btn_cal_next_month"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="▶"
            android:textSize="18sp"
            android:backgroundTint="#EEEEEE"
            android:padding="0dp" />
    </LinearLayout>

    <!-- 星期标题（仅日模式显示） -->
    <LinearLayout
        android:id="@+id/ll_week_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp"
        android:visibility="gone">
        <TextView style="@style/CalDayHeader" android:text="日"/>
        <TextView style="@style/CalDayHeader" android:text="一"/>
        <TextView style="@style/CalDayHeader" android:text="二"/>
        <TextView style="@style/CalDayHeader" android:text="三"/>
        <TextView style="@style/CalDayHeader" android:text="四"/>
        <TextView style="@style/CalDayHeader" android:text="五"/>
        <TextView style="@style/CalDayHeader" android:text="六"/>
    </LinearLayout>

    <!-- 日模式的日历网格容器 -->
    <LinearLayout
        android:id="@+id/ll_calendar_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible" />

    <!-- 月/年模式的滚轮选择器 -->
    <NumberPicker
        android:id="@+id/np_wheel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />
</LinearLayout>